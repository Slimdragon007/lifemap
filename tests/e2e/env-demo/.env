# E2E demo-mode env directory (loaded via `vite --envDir tests/e2e/env-demo`).
#
# Deliberately omits VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY so the app's
# `isSupabaseConfigured` resolves false and it renders the one-click
# "Login as Alex Kim" demo login. Pointing Vite at this dir keeps the real
# root .env.local out of the demo build entirely (no precedence guesswork).
VITE_API_ORIGIN=http://127.0.0.1:8787
