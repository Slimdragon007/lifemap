{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "lifemap-api",
  "tail_consumers": [{ "service": "ops-tail" }],
  "main": "lifemap-api.mjs",
  "compatibility_date": "2026-06-13",
  "vars": {
    "OPENAI_MODEL": "gpt-5.5",
    "ALLOWED_ORIGIN": "https://app.getlifemap.com,https://getlifemap.com,https://lifemap-d33.pages.dev,https://slimdragon007.github.io,http://localhost:5173,http://127.0.0.1:5173",
    "SUPABASE_URL": "https://tljijkoqfnimnkpzhozy.supabase.co",
    "SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRsamlqa29xZm5pbW5rcHpob3p5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE0MDAxNjgsImV4cCI6MjA5Njk3NjE2OH0.uSR4xvb-l-WDhwgMlnQgUmzYAfoftudRo-Mu2H11BRo",
    "SEND_FROM": "notify@getlifemap.com",
    "GOOGLE_CLIENT_ID": "807889635813-cq0209kb4t0r88runce2toekbng9os2s.apps.googleusercontent.com",
    "GOOGLE_REDIRECT_URI": "https://lifemap-api.m-haslim.workers.dev/api/google/callback",
    "APP_ORIGIN": "https://app.getlifemap.com",
    "NOTION_FEEDBACK_DB_ID": "5d8e44ecd9d349ad96d9c52690bc524c",
    "DAILY_AI_LIMIT": "500",
  },
  // Serverless uptime watch: pings the app + /health every 15 min and emails on
  // a state change. Runs on Cloudflare's network (the scheduled() handler).
  "triggers": {
    "crons": ["*/15 * * * *"],
  },
  "send_email": [{ "name": "EMAIL" }],
  "kv_namespaces": [
    { "binding": "GOOGLE_TOKENS", "id": "5a0a54b67b004ed89ac150c81f6df8bf" },
  ],
  // Per-IP rate limit for the unauthenticated AI endpoints (/api/analyze,
  // /api/classify, /api/brief) — they proxy OpenAI and are open to the internet.
  // 20 requests / 60s / IP. period must be 10 or 60.
  "ratelimits": [
    {
      "name": "AI_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 20, "period": 60 },
    },
  ],
  "secrets": {
    "required": [
      "OPENAI_API_KEY",
      "FIELD_ENCRYPTION_KEY",
      "GOOGLE_CLIENT_SECRET",
      "GOOGLE_OAUTH_STATE_SECRET",
    ],
  },
}
